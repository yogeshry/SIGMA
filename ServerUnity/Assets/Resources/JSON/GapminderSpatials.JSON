[

     {
    "id": "bboxPublishTab",
    "description": "Continuously publish the bounding box (corners) of device A.",
    "entities": {
        "deviceA": {
          // "name": "Tab1",
          "constraint": {
            "type": "Mobile",
            "width": { "eq": 1920 },
            "height": { "eq": 1200 },
            "ppi": { "eq": 206 }
          }
        }
    },
    "on": "always",
    "publish": { "streams": [ "A.corners" ], 
  "mapping": {
            "fromPixelA": [[96,1120]]}
  }
  },
      {
    "id": "rightSideProximity",
    "description": "A’s forward vector points to the Edge of B.",
    "entities": {         
        "deviceB": {
          // "name": "Mobile1",
          "constraint": {
            "type": "Mobile",
            "width": { "eq": 1080 },
            "height": { "eq": 2340 },
            "ppi": { "eq": 395 }
          }
        },
        "deviceA": {
          // "name": "Tab1",
          "constraint": {
            "type": "Mobile",
            "width": { "eq": 1920 },
            "height": { "eq": 1200 },
            "ppi": { "eq": 206 }
          }
        }
      },
    "condition": { "operator": "AND", "primitives": [ "coLocalLevel", "parallelEdge", "proximateLateralEdge"] },
    "on": "true",
    "publish": { "streams": [ "primitives.proximateLateralEdge.measurement", "A.rightEdge", "B.leftEdge" ]
    // ,
          // "mapping": {
          //   "toPixelA": ["primitives.forwardPointerToBottomEdge.measurement"], // custom ["A.corners"] // from stream
          //   "toPixelB": ["primitives.forwardPointerToBottomEdge.measurement"] // custom
          //   }
        } 
  },      
