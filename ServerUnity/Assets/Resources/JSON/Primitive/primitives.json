{
  "config": {
    "metrics": {
      "distance": { "unit": "cm", "tol": 1 },
      "angle": { "unit": "deg", "tol": 5 },
      "time": { "unit": "ms" },
      "velocity": { "unit": "cm/s" },
      "acceleration": { "unit": "cm/s^2" }
    }
  },

  "entities": [
    {
      "name": "tab1",
      "match": {
        "type": "Tablet",
        "ppi": { "eq": 206 },
        "width_px": { "eq": 1920 },
        "height_px": { "eq": 1200 }
      }
    },
    {
      "name": "mobile1",
      "match": {
        "type": "Mobile",
        "ppi": { "eq": 395 },
        "width_px": { "eq": 1080 },
        "height_px": { "eq": 2340 }
      }
    }
  ],

  "predicates": [
    {
      "name": "side_by_side_contact",
      "description": "Displays touching along left/right edges and coplanar",
      "$and": [
        { "contact": { "refs": ["A.rightEdge", "B.leftEdge"] } },
        { "aligned": { "axis": "up" } }
      ]
    },
    {
      "name": "side_by_side_proximate",
      "description": "Displays is proximate along left/right edges and coplanar",
      "$and": [
        {
          "proximate": {
            "refs": ["A.rightEdge", "B.leftEdge"],
            "range": [0, 12]
          }
        },
        { "aligned": { "axis": "up" } }
      ]
    },
    {
      "name": "bottom_top_stack",
      "description": "Displays touching along top/bottom edges and coplanar",
      "$and": [
        { "aligned": { "axis": "up" } },
        { "contact": { "refs": ["A.bottomEdge", "B.topEdge"] } }
      ]
    },

    {
      "name": "lateral_edge_slide",
      "description": "Forward sliding motion while left/right edges remain in contact",
      "$and": [
        { "contact": { "refs": ["A.rightEdge", "B.leftEdge"] } },
        { "aligned": { "axis": "up" } },
        { "approach": { "dir": "A.forward", "acceleration": 40 } },
        {
          "dwell": { "duration": 400 }
        }
      ]
    },
    {
      "name": "side_by_side_approach",
      "description": "Approaching  left edge of A towards right edge of B with acceleration",
      "$and": [
        { "contact": { "refs": ["A.rightEdge", "B.leftEdge"] } },
        { "aligned": { "axis": "up" } },
        { "approach": { "dir": "A.right", "acceleration": 40 } }
      ]
    },

    {
      "name": "corner_contact_BL_TR",
      "description": "Bottom-left corner of displayA touches top-right corner of displayB",
      "$and": [
        { "contact": { "refs": ["A.bottomLeftCorner", "B.topRightCorner"] } }
      ]
    },

    {
      "name": "pivot_bottom_left_corner",
      "description": "Devices pivot along bottom-left corner",
      "$and": [
        { "contact": { "refs": ["A.bottomLeftCorner", "B.rightEdge"] } },
        { "aligned": { "axis": "up" } },
        { "inclined": { "axis": "forward", "range": [5, 90] } }
      ]
    },

    {
      "name": "is_above",
      "description": "One display is above others with vertical proximity(5-50cm)",
      "$and": [
        { "aligned": { "axis": "up" } },
        {
          "proximate": {
            "refs": ["A.position", "B.position"],
            "dir": "Y",
            "range": [5, 50]
          }
        }
      ]
    }
  ],

  "interactions": [
    {
      "name": "offload_filter_UI_to_Mobile",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "side_by_side_approach",
      "events": [{ "name": "offload_filter_UI", "on": "enter" }]
    },
    {
      "name": "change_filter_coupling",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "side_by_side_proximate",
      "states": [
        {
          "name": "filter_opacity",
          "on": true,
          "stream": "proximate.distance",
          "quant": { "step": 5 },
          "map": { "in": [0, 12], "out": [0, 1] }
        },
        {
          "name": "level_of_detail",
          "on": true,
          "stream": "proximate.distance",
          "quant": { "step": 5 },
          "bins": [
            { "range": [0, 3], "value": 3 },
            { "range": [3, 8], "value": 2 },
            { "range": [8, 12], "value": 1 }
          ]
        }
      ]
    },
    {
      "name": "offload_animation_UI_to_Mobile",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "slide_along_right_edge",
      "events": [{ "name": "offload_animation_UI", "on": "enter" }]
    },
    {
      "name": "offload_X_Config_UI_Tab_to_Mobile",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "bottom_top_stack",
      "events": [{ "name": "offload_X_Config_UI", "on": "enter" }]
    },
    {
      "name": "offload_Y_Config_UI_Tab_to_Mobile",
      "roles": { "A": "mobile1", "B": "tab1" },
      "predicate": "side_by_side_contact",
      "events": [{ "name": "offload_Y_Config_UI", "on": "enter" }]
    },
    {
      "name": "offload_Z_Config_UI_Tab_to_Mobile",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "corner_contact_BL_TR",
      "events": [{ "name": "offload_Z_Config_UI", "on": "enter" }]
    },
    {
      "name": "update_composite_index",
      "roles": { "A": "tab1", "B": "mobile1" },
      "predicate": "pivot_bottom_left_corner",
      "events": [{ "name": "offload_composite_index_UI", "on": "enter" }],
      "states": [
        {
          "name": "X_percent",
          "on": true,
          "stream": "inclined.angle",
          "quant": { "step": 5 },
          "map": { "in": [0, 90], "out": [0, 100] }
        }
      ]
    },
    {
      "name": "increase_chart_height",
      "roles": { "A": "mobile1", "B": "tab1" },
      "predicate": "is_above",
      "states": [
        {
          "name": "height",
          "on": true,
          "stream": "proximate.distance"
        }
      ]
    }
  ]
}
